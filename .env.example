# Copy this file to .env and fill in ONE of the API options below.
# cp .env.example .env

# ─── HACKATHON EVALUATOR SETUP (required variables) ─────────────────────────
# The evaluator will inject these three variables. Set them to your chosen LLM:
# HF_TOKEN=<api_key_for_your_llm_provider>
# API_BASE_URL=<openai_compatible_endpoint>
# MODEL_NAME=<model_identifier>

# ─── OPTION A: Groq (recommended — fast, free tier) ──────────────────────────
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
# To use Groq as the hackathon endpoint, also set:
# HF_TOKEN=gsk_your_groq_api_key_here
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile

# ─── OPTION B: Together AI ($25 free credit, no rate limits) ─────────────────
# Get free credit at: https://api.together.xyz/signup
# TOGETHER_API_KEY=your_together_key_here
# HF_TOKEN=your_together_key_here
# API_BASE_URL=https://api.together.xyz/v1
# MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ─── OPTION C: Hugging Face Inference API ────────────────────────────────────
# Get token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_huggingface_token_here
# API_BASE_URL=https://api-inference.huggingface.co/models/meta-llama/Llama-3.1-70B-Instruct/v1
# MODEL_NAME=meta-llama/Llama-3.1-70B-Instruct
